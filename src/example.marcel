load stdlib as std;
load graphs as g;
load linalg as l;

int x = 67;
sym a;
sym b;

claim a = 3 + (-3455);
claim b = 2;
claim a = b;

mat<int, a@b> M = [[1, 2, 3], [4, 5, 6], [7, 8, 9]];

mat<int, a@b> N = l::inverse(M);  # this works because M is a square matrix

while (x > 0) {
    print("x is positive");
    x = x - 1;
}

fn factorial(n: int) -> int {
    if (n == 0) {
        return 1;
    } else {
        return n * factorial(n - 1);
    }
}